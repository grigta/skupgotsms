# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Numeric Telegram user id(s) allowed to use the bot — comma-separated for multiple
# e.g. TELEGRAM_USER_ID=11111111,22222222
TELEGRAM_USER_ID=

# API token from https://app.gotsms.org profile (after enabling API access)
GOTSMS_API_TOKEN=

# Optional: gotsms base url override
GOTSMS_BASE_URL=https://app.gotsms.org

# Optional: SQLite db path
DB_PATH=data/skupgotsms.sqlite

# Default autobuy interval in minutes
DEFAULT_AUTOBUY_INTERVAL_MIN=5
